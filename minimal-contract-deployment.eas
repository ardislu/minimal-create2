;; This is the minimal bytecode that can be used to deploy a new smart contract
CODESIZE ; [size]
PUSH0    ; [offset, size]
DUP2     ; [size, offset, size]
PUSH0    ; [offset, size, offset, size]
MSTORE8  ; [offset, size]
RETURN   ; []

;;; This smart contract, compiled:
;;; 385f815f53f3

;;; When sent to EVM, this smart contract will deploy a new smart contract with bytecode:
;;; 060000000000
